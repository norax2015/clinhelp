# ClinHelp Environment Variables
# Copy this to .env and fill in values

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://clinhelp:password@localhost:5432/clinhelp_dev"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── S3 / Object Storage ─────────────────────────────────────────────────────
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="clinhelp-files"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"

# ─── AI Provider ─────────────────────────────────────────────────────────────
AI_MODE="mock"  # "mock" for dev, "openai" or "anthropic" for production
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── Speech-to-Text ──────────────────────────────────────────────────────────
STT_PROVIDER="mock"  # "mock", "deepgram", "assembly"
DEEPGRAM_API_KEY=""
ASSEMBLYAI_API_KEY=""

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_PORT=3001

# ─── Email (optional for MVP) ─────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="noreply@clinhelp.ai"
